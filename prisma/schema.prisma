generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  firstName    String
  lastName     String
  email        String        @unique
  role         String        @default("USER")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  password     String
  phone        String?
  appointments Appointment[]
  notes        CallNote[]
  supportCalls SupportCall[]
  tasks        Task[]
}

model Practice {
  id            Int           @id @default(autoincrement())
  practiceName  String
  contactPerson String?
  email         String?
  phone         String?
  addressLine   String?
  city          String?
  province      String?
  postalCode    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  appointments  Appointment[]
  supportCalls  SupportCall[]
}

model SupportCall {
  id          Int        @id @default(autoincrement())
  practiceId  Int
  userId      Int?
  subject     String
  description String?
  priority    String     @default("Medium")
  status      String     @default("Open")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  notes       CallNote[]
  practice    Practice   @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  user        User?      @relation(fields: [userId], references: [id])
}

model CallNote {
  id            Int         @id @default(autoincrement())
  supportCallId Int
  userId        Int?
  note          String
  createdAt     DateTime    @default(now())
  pdatedAt      DateTime
  supportCall   SupportCall @relation(fields: [supportCallId], references: [id])
  user          User?       @relation(fields: [userId], references: [id])
}

model Task {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  priority    String    @default("Medium")
  status      String    @default("Pending")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Appointment {
  id              Int      @id @default(autoincrement())
  practiceId      Int
  userId          Int?
  title           String
  appointmentDate DateTime
  description     String?
  status          String   @default("Scheduled")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  practice        Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  user            User?    @relation(fields: [userId], references: [id])
}
